{% assign page_lang = page.lang | default: site.lang | default: 'en' %}
{% assign is_zh = false %}
{% if page_lang == 'zh-CN' or page.url contains '/zh/' %}
  {% assign is_zh = true %}
{% endif %}

{% if is_zh %}
  {% assign home_url = '/zh/' %}
  {% assign switch_en_url = page.alternate_url | default: '/' %}
  {% assign switch_zh_url = page.url %}
{% else %}
  {% assign home_url = '/' %}
  {% assign switch_en_url = page.url %}
  {% assign switch_zh_url = page.alternate_url | default: '/zh/' %}
{% endif %}

<header>
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% endif %}" role="navigation">
    <div class="container">
      <a class="navbar-brand title font-weight-lighter" href="{{ home_url | relative_url }}">
        {% if site.title == 'blank' %}
          <span class="font-weight-bold">{{ site.first_name }}</span>
          {{ site.middle_name }}
          {{ site.last_name }}
        {% else %}
          {{ site.title }}
        {% endif %}
      </a>

      <button
        class="navbar-toggler collapsed ml-auto"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="collapse navbar-collapse text-right" id="navbarNav">
        <ul class="navbar-nav ml-auto flex-nowrap navbar-menu-list">
          {% if is_zh %}
            {% assign zh_nav_pages = site.data.navigation_zh.pages | sort: 'order' %}
            {% for nav_page in zh_nav_pages %}
              <li class="nav-item {% if page.url == nav_page.url %}active{% endif %}">
                <a class="nav-link" href="{{ nav_page.url | relative_url }}">{{ nav_page.title }}</a>
              </li>
            {% endfor %}
          {% else %}
            {% assign nav_pages = site.pages | where: 'nav', true | sort: 'nav_order' %}
            {% for nav_page in nav_pages %}
              {% unless nav_page.lang == 'zh-CN' or nav_page.url contains '/zh/' %}
                <li class="nav-item {% if page.url == nav_page.url %}active{% endif %}">
                  <a class="nav-link" href="{{ nav_page.url | relative_url }}">{{ nav_page.title }}</a>
                </li>
              {% endunless %}
            {% endfor %}
          {% endif %}

          <li class="nav-item language-switcher">
            {% if is_zh %}
              <a class="nav-link" href="{{ switch_en_url | relative_url }}" hreflang="en">EN</a>
              <span class="nav-link active-language" aria-current="true">中文</span>
            {% else %}
              <span class="nav-link active-language" aria-current="true">EN</span>
              <a class="nav-link" href="{{ switch_zh_url | relative_url }}" hreflang="zh-CN">中文</a>
            {% endif %}
          </li>

          {% if site.search_enabled %}
            <li class="nav-item">
              <button id="search-toggle" class="nav-link btn btn-link search-toggle" type="button" aria-label="Search">
                <i class="fa-solid fa-magnifying-glass"></i>
              </button>
            </li>
          {% endif %}

          {% if site.enable_darkmode %}
            <li class="toggle-container">
              <button id="light-toggle" title="Change theme" aria-label="Change theme">
                <i class="fa-solid fa-moon"></i>
                <i class="fa-solid fa-sun"></i>
              </button>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>
</header>
